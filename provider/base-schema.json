{
  "name": "anvil",
  "version": "0.0.4",
  "language": {
    "nodejs": {
      "packageName": "@@anvil-cloud/sdk",
      "dependencies": {
        "@pulumi/pulumi": "^3.0.0",
        "@pulumi/aws": "^7.21.0",
        "@pulumi/gcp": "^9.0.0"
      }
    },
    "python": {
      "packageName": "anvil_cloud",
      "requires": {
        "pulumi": ">=3.0.0,<4.0.0",
        "pulumi-aws": "^7.21.0",
        "pulumi-gcp": "^9.0.0"
      }
    },
    "go": {
      "generateResourceContainerTypes": true,
      "importBasePath": "github.com/DamienPace15/anvil/sdk/go/anvil"
    },
    "csharp": {
      "packageReferences": {
        "Pulumi": "3.*",
        "Pulumi.Aws": "7.*"
      },
      "rootNamespace": "Anvil"
    },
    "java": {
      "basePackage": "com.anvil.pulumi",
      "buildFiles": "gradle"
    }
  },
  "resources": {},
  "types": {}
}
